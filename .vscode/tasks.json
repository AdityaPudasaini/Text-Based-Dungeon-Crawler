{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build with GCC 15.2.0",
            "command": "C:\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++20",
                "${workspaceFolder}\\main.cpp",
                "${workspaceFolder}\\Enemy\\enemy.cpp",
                "${workspaceFolder}\\Enemy\\commonEnemy.cpp",
                "${workspaceFolder}\\Enemy\\bossEnemy.cpp",
                "${workspaceFolder}\\Player\\player.cpp",
                "${workspaceFolder}\\Gameplay\\gameplay.cpp",
                "-o",
                "${workspaceFolder}\\rooster.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "compiler: C:\\mingw64\\bin\\g++.exe"
        },
        {
            "type": "cppbuild",
            "label": "Build with MSVC",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/std:c++latest",
                "/EHsc",
                "/Fe:",
                "${workspaceFolder}\\rooster.exe",
                "${workspaceFolder}\\main.cpp",
                "${workspaceFolder}\\Enemy\\enemy.cpp",  
                "${workspaceFolder}\\Enemy\\commonEnemy.cpp",
                "${workspaceFolder}\\Enemy\\bossEnemy.cpp",
                "${workspaceFolder}\\Player\\player.cpp",
                "${workspaceFolder}\\Gameplay\\gameplay.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build",
            "detail": "compiler: cl.exe"
        }
    ]
}